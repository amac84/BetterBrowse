{
  "name": "@amac84/betterbrowse-core",
  "version": "0.1.2",
  "description": "Core BetterBrowse auditing engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amac84/BetterBrowse"
  },
  "bugs": {
    "url": "https://github.com/amac84/BetterBrowse/issues"
  },
  "homepage": "https://github.com/amac84/BetterBrowse#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
