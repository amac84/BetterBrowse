    "playwright": "^1.53.0",
    "ts-morph": "^25.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
