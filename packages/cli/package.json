{
  "name": "@amac84/betterbrowse",
  "version": "0.1.2",
  "description": "CLI-native web app auditor for React, Next.js, and static HTML projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amac84/BetterBrowse"
  },
  "bugs": {
    "url": "https://github.com/amac84/BetterBrowse/issues"
  },
  "homepage": "https://github.com/amac84/BetterBrowse#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "preferGlobal": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "betterbrowse": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepack": "npm run build",
    "typecheck": "tsc -b --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "betterbrowse",
    "ui",
    "ux",
    "audit",
    "cli",
    "nextjs",
    "react",
    "html",
    "accessibility"
  ],
  "dependencies": {
    "@amac84/betterbrowse-core": "^0.1.2",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3"
  }
}
